
resource "vault_mount" "pki_root_homelab" {
  path                  = "pki-root-homelab"
  type                  = "pki"
  max_lease_ttl_seconds = 315360000
}

resource "vault_pki_secret_backend_root_cert" "root" {
  backend     = vault_mount.pki_root_homelab.path
  type        = "internal"
  common_name = "Homelab Root CA"
  ttl         = "315360000"
  key_type    = "rsa"
  key_bits    = 4096
}

