pid_file = "/run/vault-agent/vault-agent.pid"

vault {
  address = "{{ vault_agent_vault_addr }}"
}

auto_auth {
  method "approle" {
    mount_path = "auth/approle"
    config = {
      role_id_file_path   = "/etc/vault/role-id"
      secret_id_file_path = "/etc/vault/secret-id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/var/run/vault/token"
    }
  }
}

template_config {
  exit_on_retry_failure = true
  static_secret_render_interval = "10m"
  max_connections_per_host = 20
}

{% if 'loadbalancer' in inventory_hostname %}

template {
  source      = "/etc/vault/templates/grafana.tpl"
  destination = "/etc/haproxy/certs/grafana.pem"
  command     = "sudo systemctl reload haproxy"
}

template {
  source      = "/etc/vault/templates/keycloak.tpl"
  destination = "/etc/haproxy/certs/keycloak.pem"
  command     = "sudo systemctl reload haproxy"
}

template {
  source      = "/etc/vault/templates/vault.tpl"
  destination = "/etc/haproxy/certs/vault.pem"
  command     = "sudo systemctl reload haproxy"
}

template {
  source      = "/etc/vault/templates/s3.tpl"
  destination = "/etc/haproxy/certs/s3.pem"
  command     = "sudo systemctl reload haproxy"
}

{% endif %}
